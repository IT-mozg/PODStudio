# --- секрети / особисті налаштування ---
# ui_config.json містить API-ключ OpenAI (і, за бажанням, баланс) - НІКОЛИ
# не комітити.
ui_config.json
.env
*.pem
*.key

# --- особисті дані користувача ---
# history.json - персональна історія генерацій (назви, промпти, дати).
history.json

# pages/ - вручну збережені сторінки Etsy (пошук/магазин/обране) разом з
# супутніми папками "..._files/" (картинки, JS, CSS самого Etsy, які Chrome
# зберігає поруч з .html). Це чужий/копірайтний контент з Etsy - не повинен
# публікуватись на GitHub, і саме це Etsy не має бачити в репозиторії (може
# виглядати як докази скрапінгу, навіть якщо технічно це просто збережені
# локально файли).
pages/*
!pages/.gitkeep

# refs/ - завантажені референс-картинки конкурентів (копірайт чужих робіт).
refs/

# output/ - згенеровані дизайни - це вже твої результати, не секрет, але
# й не те, що варто тягнути в публічний репозиторій (великі бінарники,
# особисті напрацювання).
output/

# browser_profile/ - залишок від старої функції живого пошуку (видалено з
# коду), про всяк випадок ігноруємо, якщо колись з'явиться знову.
browser_profile/

# vendor/ - realesrgan-ncnn-vulkan binary + model weights, downloaded on
# first use of the upscale editing action (see models/upscale.py). Large
# binaries, platform-specific - not something to commit.
vendor/

# --- службове ---
__pycache__/
*.pyc
.DS_Store
.claude/
